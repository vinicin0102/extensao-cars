document.addEventListener("DOMContentLoaded", () => {
  const totalEl = document.getElementById("total");
  const verdesEl = document.getElementById("verdes");
  const amarelosEl = document.getElementById("amarelos");
  const vermelhosEl = document.getElementById("vermelhos");
  const topList = document.getElementById("top-list");
  const alertsList = document.getElementById("alerts-list");

  function loadData() {
    chrome.runtime.sendMessage({ type: "GET_CARS" }, (cars) => {
      if (!cars || cars.length === 0) return;

      totalEl.textContent = cars.length;
      verdesEl.textContent = cars.filter(c => c.classificacao === "VERDE").length;
      amarelosEl.textContent = cars.filter(c => c.classificacao === "AMARELO").length;
      vermelhosEl.textContent = cars.filter(c => c.classificacao === "VERMELHO").length;

      // Top 5 melhores oportunidades
      const top = cars
        .filter(c => c.classificacao === "VERDE" && c.lucroLiquido > 0)
        .sort((a, b) => b.lucroLiquido - a.lucroLiquido)
        .slice(0, 5);

      if (top.length > 0) {
        topList.innerHTML = top.map(c => `
          <div class="deal-item">
            <span class="deal-name">${c.marca || ""} ${c.modelo}</span>
            <span class="deal-profit">+R$ ${c.lucroLiquido.toLocaleString("pt-BR")}</span>
          </div>
        `).join("");
      }

      // Alertas recentes
      const alertCars = cars.filter(c => c.alertas && c.alertas.length > 0).slice(0, 5);
      if (alertCars.length > 0) {
        alertsList.innerHTML = alertCars.map(c =>
          c.alertas.map(a => `<div class="alert-item">${c.modelo}: ${a}</div>`).join("")
        ).join("");
      }
    });
  }

  loadData();

  document.getElementById("btn-dashboard").addEventListener("click", () => {
    chrome.tabs.create({ url: "dashboard.html" });
  });

  document.getElementById("btn-clear").addEventListener("click", () => {
    chrome.runtime.sendMessage({ type: "CLEAR_CARS" }, () => {
      totalEl.textContent = "0";
      verdesEl.textContent = "0";
      amarelosEl.textContent = "0";
      vermelhosEl.textContent = "0";
      topList.innerHTML = '<p class="empty">Dados limpos!</p>';
      alertsList.innerHTML = '<p class="empty">Dados limpos!</p>';
    });
  });
});
