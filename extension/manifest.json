{
  "manifest_version": 3,
  "name": "AutoSpy - Car Arbitrage & Profit Scanner",
  "version": "1.0",
  "description": "Espie sites de carros, veja margens de lucro e os modelos mais vendidos em tempo real.",
  "permissions": ["activeTab", "scripting", "storage", "http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.webmotors.com.br/*", "*://*.olx.com.br/*"],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
